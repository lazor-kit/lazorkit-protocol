{
  "name": "lazorkit-tests-sdk",
  "version": "1.0.0",
  "private": true,
  "description": "LazorKit SDK integration tests (sdk-legacy + @solana/web3.js v1)",
  "scripts": {
    "test": "vitest run --fileParallelism=false",
    "test:watch": "vitest --fileParallelism=false",
    "test:local": "npm run validator:start & sleep 3 && npm test; npm run validator:stop",
    "validator:start": "solana-test-validator --bpf-program $(solana-keygen pubkey ../target/deploy/lazorkit_program-keypair.json) ../target/deploy/lazorkit_program.so --reset --quiet &",
    "validator:stop": "pkill -f solana-test-validator || true",
    "benchmark": "npx tsx tests/benchmark.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "ecdsa-secp256r1": "^1.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
